{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "source": ".",
    "frameworksBackend": {
      "region": "europe-west1",
      "maxInstances": 3
    },
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "secrets/**",
      "reports/**",
      "docs/**",
      "scripts/**"
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "database": { "port": 9000 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
