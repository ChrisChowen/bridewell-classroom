// Bridewell Classroom — Firestore security rules.
// v3, hardened 22 May 2026 (north-star work stream 2: auth scoping).
//
// Principles:
// - Teachers identified by custom claim `role == 'teacher'` (set by an
//   admin-SDK route on first sign-in).
// - Pupils identified by anonymous Firebase Auth UID stored on a pupil doc.
// - Server-only writes (engagement snapshots, Reason events, safeguarding,
//   profiles, interventions) go through the admin SDK, which BYPASSES these
//   rules. So those collections are locked to `read: if false` for clients —
//   nothing legitimate reads them client-side (the live dashboard reads RTDB;
//   appraisal reads via a server API).
// - Teacher reads are scoped to classes they OWN (no cross-teacher access);
//   the v2 rules leaked all teacher records + all classes + all conversations
//   to any authed user. That is closed here.
//
// Verified against the emulator by scripts/test-rules.mjs
// (run: npm run test:rules).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function isTeacher() { return isAuthed() && request.auth.token.role == 'teacher'; }
    function uid() { return request.auth.uid; }

    // True when the caller is a teacher who owns the given class.
    function classOwner(classId) {
      return isTeacher()
        && exists(/databases/$(database)/documents/classes/$(classId))
        && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == uid();
    }

    // True when the caller is a pupil enrolled in the given class.
    function pupilEnrolledIn(classId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/pupils/$(uid()))
        && get(/databases/$(database)/documents/pupils/$(uid())).data.classId == classId;
    }

    // Code → class lookup. Read server-side at join; low sensitivity
    // (random code → classId). Kept authed-readable so the join path is
    // robust; never client-writable.
    match /joinCodes/{code} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // A teacher reads/writes ONLY their own record. (v2 leaked every
    // teacher's email to any authed user.)
    match /teachers/{teacherId} {
      allow read: if isAuthed() && uid() == teacherId;
      allow create, update: if isAuthed() && uid() == teacherId;
    }

    // Owner teacher reads; enrolled pupil reads (to load the lesson plan).
    match /classes/{classId} {
      allow read: if (isTeacher() && resource.data.teacherId == uid())
                  || pupilEnrolledIn(classId);
      allow create: if isTeacher();
      allow update, delete: if isTeacher() && resource.data.teacherId == uid();
    }

    // Pupil reads own record; owner teacher reads their class's pupils.
    // Created server-side via /api/classes/join (admin SDK).
    match /pupils/{pupilId} {
      allow read: if uid() == pupilId || classOwner(resource.data.classId);
      allow create: if false;
      allow update: if uid() == pupilId || classOwner(resource.data.classId);
    }

    // Conversation id is `{classId}_{pupilUid}`. classId is the segment
    // before the first '_'. Owner teacher reads all of their class's
    // conversations; the pupil reads only their own.
    match /conversations/{conversationId} {
      allow read: if classOwner(conversationId.split('_')[0])
                  || (isAuthed() && conversationId.matches('.*_' + uid()));
      allow write: if false; // server-only via /api/conversation/append

      match /messages/{messageId} {
        allow read: if classOwner(conversationId.split('_')[0])
                    || (isAuthed() && conversationId.matches('.*_' + uid()));
        allow write: if false;
      }
    }

    // ── Server-only analytics + safeguarding (admin SDK bypasses rules).
    // No client reads any of these directly, so deny client reads outright.
    match /engagementSnapshots/{id} { allow read, write: if false; }
    match /reasonEvents/{id}        { allow read, write: if false; }
    match /learnerProfiles/{id}     { allow read, write: if false; }
    match /safeguardingEvents/{id}  { allow read, write: if false; }
    match /interventions/{id}       { allow read, write: if false; }

    // Lesson templates / sessions — teacher-authored content.
    match /lessons/{lessonId} {
      allow read: if isAuthed();
      allow write: if isTeacher();
    }
    match /sessions/{sessionId} {
      allow read: if isTeacher();
      allow create, update: if isTeacher();
    }

    // Shared-at-school library + allowlist. Teacher-readable only; written
    // server-side (with admin checks for the allowlist).
    match /lessonLibrary/{lessonId}     { allow read: if isTeacher(); allow write: if false; }
    match /allowedTeacherEmails/{email} { allow read: if isTeacher(); allow write: if false; }
    match /syllabusSuggestions/{docId=**} { allow read: if isTeacher(); allow write: if false; }
  }
}
