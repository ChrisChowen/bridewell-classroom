{
  "name": "bridewell-classroom",
  "version": "0.0.0",
  "private": true,
  "description": "Bridewell Classroom — greenfield prototype for the 29 May 2026 CDT Spring Challenge Final Presentation.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rules": "firebase emulators:exec --only firestore,auth --project bridewell-classroom \"node scripts/test-rules.mjs\"",
    "test:rtdb": "firebase emulators:exec --only database,auth --project bridewell-classroom \"node scripts/test-rtdb-rules.mjs\"",
    "test:emulator": "firebase emulators:exec --only firestore,database --project bridewell-classroom \"vitest run -c vitest.emulator.config.ts\"",
    "eval:adversarial": "export $(grep -E '^GEMINI_API_KEY=' .env.local | xargs) && RUN_LIVE_EVAL=1 vitest run src/lib/ai/adversarial-eval.live.test.ts",
    "test:a11y": "playwright test",
    "test:e2e": "firebase emulators:exec --only auth,firestore,database --project bridewell-classroom \"playwright test -c playwright.emulator.config.ts\"",
    "bench": "node scripts/benchmark.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.5.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.469.0",
    "motion": "^12.40.0",
    "next": "^15.5.18",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.5.18",
    "happy-dom": "^15.11.7",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
