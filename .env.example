# Bridewell Classroom — sample env. Copy to .env.local and fill in.
# .env.local is gitignored. Never commit real keys.

# Gemini (Google AI Studio key)
GEMINI_API_KEY=your-gemini-api-key

# Firebase web app config (Project settings → General → Your apps → Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Realtime Database URL (Firestore → Realtime DB → Data → URL at the top)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# Service account for the admin SDK. Either:
#   (a) drop the JSON file into ./secrets/ and point at it (gitignored), or
#   (b) base64-encode the JSON and put it in FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-admin.json
# FIREBASE_SERVICE_ACCOUNT_JSON=
